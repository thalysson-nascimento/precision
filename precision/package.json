{
  "name": "precision",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate:sqlite": "npm run --workspace=@precision/database db:generate:sqlite",
    "db:generate:postgres": "npm run --workspace=@precision/database db:generate:postgres",
    "db:push:sqlite": "npm run --workspace=@precision/database db:push:sqlite",
    "db:migrate:postgres": "npm run --workspace=@precision/database db:migrate:postgres",
    "db:seed": "node prisma/seed.js",
    "postinstall": "npm run db:generate:sqlite && npm run db:generate:postgres"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "dotenv": "^16.4.5",
    "pg": "^8.22.0"
  }
}
