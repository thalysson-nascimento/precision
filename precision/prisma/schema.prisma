generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id             String           @id @default(uuid())
  name           String
  email          String           @unique
  password       String           @default("123456")
  isPasswordTemp Boolean          @default(true)
  tempPassword   String?
  userRole       String           @default("EMPLOYEE") // "SUPERADMIN", "OWNER", "ADMIN", "EMPLOYEE"
  role           String           // Job title
  workStart      String           @default("08:00")
  lunchStart     String           @default("12:00")
  lunchEnd       String           @default("13:00")
  workEnd        String           @default("18:00")
  createdAt      DateTime         @default(now())
  isActive       Boolean          @default(true)
  contractNumber String?
  phone          String?
  address        String?
  isTeamLeader   Boolean          @default(false)
  teamId         String?
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        Employee?        @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates   Employee[]       @relation("EmployeeManager")
  companyId      String?
  company        Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  adjustments    TimeAdjustment[]
  records        TimeRecord[]
}

model TimeRecord {
  id         String   @id @default(uuid())
  employeeId String
  date       String
  type       String
  time       String
  confirmed  Boolean  @default(false)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date, type])
}

model TimeAdjustment {
  id            String   @id @default(uuid())
  employeeId    String
  date          String
  type          String
  time          String?
  justification String
  attachment    String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Team {
  id        String     @id @default(uuid())
  name      String
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  createdAt DateTime   @default(now())

  @@unique([name, companyId])
}

model Company {
  id                 String     @id @default(uuid())
  name               String     @unique
  address            String
  number             String
  contact            String
  country            String?
  document           String?
  corporateName      String?
  zip                String?
  street             String?
  city               String?
  state              String?
  email              String?
  subscriptionPlan   String     @default("TRIAL") // "TRIAL", "THREE_MONTHS", "SIX_MONTHS"
  subscriptionStatus String     @default("ACTIVE") // "ACTIVE", "EXPIRED"
  subscriptionEndsAt DateTime?
  createdAt          DateTime   @default(now())
  employees          Employee[]
  teams              Team[]
  jobRoles           JobRole[]
  blockages          WorkBlockage[]
  supportMessages    SupportMessage[]
}

model JobRole {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, companyId])
}

model WorkBlockage {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        String   // "WEEKDAY" or "DATE"
  dayOfWeek   Int?     // 0 = Sunday, 1 = Monday, ..., 6 = Saturday (for type === "WEEKDAY")
  date        String?  // "YYYY-MM-DD" (for type === "DATE")
  reason      String?  // e.g. "Natal", "Sexta-feira da Paixão"
  createdAt   DateTime @default(now())

  @@unique([companyId, dayOfWeek, date])
}

model SupportMessage {
  id         String   @id @default(uuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  senderId   String
  senderName String
  senderRole String   // "SUPERADMIN" or "OWNER"/"ADMIN"
  text       String
  createdAt  DateTime @default(now())
}
