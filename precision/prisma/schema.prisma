generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Employee {
  id             String           @id @default(uuid())
  name           String
  email          String           @unique
  password       String           @default("123456")
  userRole       String           @default("EMPLOYEE") // "SUPERADMIN", "OWNER", "ADMIN", "EMPLOYEE"
  role           String           // Job title
  workStart      String           @default("08:00")
  lunchStart     String           @default("12:00")
  lunchEnd       String           @default("13:00")
  workEnd        String           @default("18:00")
  createdAt      DateTime         @default(now())
  isActive       Boolean          @default(true)
  contractNumber String?
  phone          String?
  address        String?
  isTeamLeader   Boolean          @default(false)
  teamId         String?
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  managerId      String?
  manager        Employee?        @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates   Employee[]       @relation("EmployeeManager")
  companyId      String?
  company        Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  adjustments    TimeAdjustment[]
  records        TimeRecord[]
}

model TimeRecord {
  id         String   @id @default(uuid())
  employeeId String
  date       String
  type       String
  time       String
  confirmed  Boolean  @default(false)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date, type])
}

model TimeAdjustment {
  id            String   @id @default(uuid())
  employeeId    String
  date          String
  type          String
  time          String?
  justification String
  attachment    String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Team {
  id        String     @id @default(uuid())
  name      String
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]
  createdAt DateTime   @default(now())

  @@unique([name, companyId])
}

model Company {
  id                 String     @id @default(uuid())
  name               String     @unique
  address            String
  number             String
  contact            String
  subscriptionPlan   String     @default("TRIAL") // "TRIAL", "THREE_MONTHS", "SIX_MONTHS"
  subscriptionStatus String     @default("ACTIVE") // "ACTIVE", "EXPIRED"
  subscriptionEndsAt DateTime?
  createdAt          DateTime   @default(now())
  employees          Employee[]
  teams              Team[]
  jobRoles           JobRole[]
}

model JobRole {
  id        String   @id @default(uuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([name, companyId])
}
